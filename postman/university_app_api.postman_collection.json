        {
          "name": "POST /auth/register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data && data.data) {",
                  "    if (data.data.access_token) pm.collectionVariables.set('token', data.data.access_token);",
                  "    if (data.data.refresh_token) pm.collectionVariables.set('refresh_token', data.data.refresh_token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"academic_number\": \"441234567\",\n  \"password\": \"12345678\",\n  \"full_name\": \"Test User\",\n  \"department\": \"Computer Science\",\n  \"academic_level\": \"Level 6\",\n  \"bio\": \"API test account\"\n}"
